services:
  traefik:
    image: {{ traefik_image }}
    container_name: traefik
    env_file: .env
    ports:
      - "80:80"
      - "443:443"
    security_opt:
      - no-new-privileges:true
    volumes:
      - {{ traefik_data_dir }}/acme.json:/acme.json
      - {{ traefik_data_dir }}/traefik.yml:/traefik.yml:ro
      - /etc/localtime:/etc/localtime:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      - CF_API_EMAIL=${TRAEFIK_CF_API_EMAIL}
      - CF_DNS_API_TOKEN=${TRAEFIK_CF_DNS_API_TOKEN}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.traefik-secure.entrypoints=https"
      - "traefik.http.routers.traefik-secure.rule=Host(`{{ traefik_dashboard_url }}`)"
      - "traefik.http.routers.traefik-secure.tls=true"
      - "traefik.http.routers.traefik-secure.tls.certresolver=cloudflare"
      - "traefik.http.routers.traefik-secure.tls.domains[0].main={{ global_base_url }}"
      - "traefik.http.routers.traefik-secure.tls.domains[0].sans=*.{{ global_base_url }}"
      - "traefik.http.routers.traefik-secure.service=api@internal"
      - "traefik.http.routers.traefik-secure.middlewares=authelia@docker"
    networks:
      - traefik
    restart: unless-stopped

networks:
  traefik:
    external: true